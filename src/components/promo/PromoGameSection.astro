---
import PromoFlowPanel from './PromoFlowPanel.astro';
import PromoWheel from './PromoWheel.astro';
---

<section id="ruleta" class="mx-auto max-w-7xl px-5 py-12 lg:px-10">
  <div class="rounded-[2.4rem] border border-[#ead8ec] bg-white p-5 shadow-[0_28px_90px_rgba(43,22,47,.12)] md:p-8">
    <div class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
      <div>
        <p class="text-xs font-black uppercase tracking-[0.28em] text-[#b76bc0]">
          Ruleta oficial
        </p>

        <h2 class="mt-2 text-3xl font-black text-[#1f2024]">
          Participa aquí
        </h2>
      </div>

      <div
        data-status-pill
        class="w-fit rounded-full border border-[#ead8ec] bg-[#fbf2fc] px-4 py-2 text-xs font-bold text-[#b76bc0]"
      >
        Registro pendiente
      </div>
    </div>

    <div
      data-toast
      class="mb-4 hidden rounded-2xl border px-4 py-3 text-sm font-semibold"
    ></div>

    <div class="grid gap-10 xl:grid-cols-[0.85fr_1.15fr] xl:items-center">
      <PromoFlowPanel />
      <PromoWheel />
    </div>
  </div>
</section>
