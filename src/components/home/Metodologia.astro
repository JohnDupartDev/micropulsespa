---
// src/components/Metodologia.astro
---



<main class="flex-1 bg-white">
  <!-- SECCIÓN PRINCIPAL -->
  <section class="relative py-20 md:py-28 px-4 sm:px-6 overflow-hidden" id="como-funciona">
    <!-- Elementos decorativos de fondo -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-20 left-10 w-72 h-72 bg-brand-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-20 right-10 w-96 h-96 bg-brand-primary/5 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-5xl mx-auto">
      <!-- HEADER DE SECCIÓN MEJORADO -->
      <div class="text-center mb-20">
        <div class="reveal opacity-0 translate-y-8 transition-all duration-700">
          <!-- Badge animado -->
          <div class="inline-flex items-center gap-2 bg-brand-primary/10 px-5 py-2 rounded-full mb-6 border border-brand-primary/20">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-primary"></span>
            </span>
            <span class="text-xs font-black tracking-[0.25em] uppercase text-brand-primary">Metodología</span>
          </div>

          <!-- Título con efecto de desborde -->
          <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black mb-6 tracking-tighter text-brand-dark leading-[1.1]">
            ¿Cómo <span class="relative inline-block">
              <span class="relative z-10 text-brand-primary ">funciona</span>
              <span class="absolute -bottom-2 left-0 w-full h-3 bg-brand-primary/20 -rotate-1 rounded-full"></span>
            </span>?
          </h2>

          <!-- Descripción con mayor jerarquía -->
          <p class="text-lg md:text-xl text-slate-600 leading-relaxed font-medium max-w-2xl mx-auto">
            Nuestro método combina ciencia y bienestar para transformar la textura de tu piel de manera segura, gradual y personalizada.
          </p>
        </div>
      </div>

      <!-- TIMELINE DE PASOS MEJORADO -->
      <div class="relative">
        <!-- Línea de tiempo central (solo escritorio) -->
        <div class="hidden lg:block absolute left-1/2 top-8 bottom-8 w-0.5 bg-gradient-to-b from-brand-primary/40 via-brand-primary/20 to-transparent -translate-x-1/2"></div>

        <div class="space-y-16 lg:space-y-24 relative">
          <!-- PASO 1 -->
          <div class="reveal opacity-0 translate-y-10 transition-all duration-700 delay-100">
            <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
              <!-- Número con diseño mejorado -->
              <div class="relative shrink-0 order-1 lg:order-1 lg:w-1/3 lg:text-right">
                <div class="inline-block">
                  <div class="absolute inset-0 bg-brand-primary/20 rounded-3xl blur-xl"></div>
                  <div class="relative w-20 h-20 lg:w-24 lg:h-24 rounded-3xl bg-gradient-to-br from-brand-primary to-brand-primary/80 text-white flex items-center justify-center text-3xl lg:text-4xl font-black shadow-2xl shadow-brand-primary/30">
                    01
                  </div>
                </div>
              </div>

              <!-- Contenido -->
              <div class="flex-1 text-center lg:text-left order-2 lg:order-2 lg:w-2/3">
                <div class="flex flex-col lg:flex-row lg:items-center gap-4 mb-4 justify-center lg:justify-start">
                  <h3 class="text-2xl lg:text-3xl font-black text-brand-dark">
                    Valoración Personalizada
                  </h3>
                  <div class="w-10 h-10 rounded-xl bg-brand-primary/10 flex items-center justify-center shrink-0 mx-auto lg:mx-0">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                  </div>
                </div>
                <p class="text-slate-600 text-lg leading-relaxed max-w-2xl mx-auto lg:mx-0">
                  Nuestro equipo determinará tus objetivos dependiendo del estado de tu piel mediante un <span class="font-semibold text-brand-dark">análisis profundo</span> y personalizado.
                </p>
                <!-- Detalle adicional -->
                <div class="mt-4 flex items-center gap-2 justify-center lg:justify-start text-sm text-brand-primary/70">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
                  <span>Duración: 45-60 minutos</span>
                </div>
              </div>
            </div>
          </div>

          <!-- PASO 2 (alternado) -->
          <div class="reveal opacity-0 translate-y-10 transition-all duration-700 delay-200">
            <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
              <!-- Contenido (en lg va primero) -->
              <div class="flex-1 text-center lg:text-right order-2 lg:order-1 lg:w-2/3">
                <div class="flex flex-col lg:flex-row lg:items-center lg:justify-end gap-4 mb-4">
                  <div class="w-10 h-10 rounded-xl bg-brand-primary/10 flex items-center justify-center shrink-0 mx-auto lg:mx-0 order-2 lg:order-1">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                      <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                  </div>
                  <h3 class="text-2xl lg:text-3xl font-black text-brand-dark order-1 lg:order-2">
                    Sesiones Cada 28 Días
                  </h3>
                </div>
                <p class="text-slate-600 text-lg leading-relaxed max-w-2xl mx-auto lg:ml-auto">
                  Respetamos el <span class="font-semibold text-brand-dark">ciclo natural de regeneración celular</span>, permitiendo que tu piel se recupere y se beneficie al máximo.
                </p>
                <!-- Barra de progreso visual -->
                <div class="mt-4 flex items-center gap-2 justify-center lg:justify-end">
                  <div class="w-24 h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div class="h-full w-1/3 bg-brand-primary rounded-full"></div>
                  </div>
                  <span class="text-sm text-slate-500">Ciclo completo</span>
                </div>
              </div>

              <!-- Número -->
              <div class="relative shrink-0 order-1 lg:order-2 lg:w-1/3">
                <div class="inline-block lg:float-right">
                  <div class="absolute inset-0 bg-brand-primary/20 rounded-3xl blur-xl"></div>
                  <div class="relative w-20 h-20 lg:w-24 lg:h-24 rounded-3xl bg-white border-2 border-brand-primary text-brand-primary flex items-center justify-center text-3xl lg:text-4xl font-black shadow-xl">
                    02
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- PASO 3 -->
          <div class="reveal opacity-0 translate-y-10 transition-all duration-700 delay-300">
            <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12">
              <div class="relative shrink-0 order-1 lg:order-1 lg:w-1/3 lg:text-right">
                <div class="inline-block">
                  <div class="absolute inset-0 bg-brand-primary/20 rounded-3xl blur-xl"></div>
                  <div class="relative w-20 h-20 lg:w-24 lg:h-24 rounded-3xl bg-white border-2 border-brand-primary text-brand-primary flex items-center justify-center text-3xl lg:text-4xl font-black shadow-xl">
                    03
                  </div>
                </div>
              </div>

              <div class="flex-1 text-center lg:text-left order-2 lg:order-2 lg:w-2/3">
                <div class="flex flex-col lg:flex-row lg:items-center gap-4 mb-4 justify-center lg:justify-start">
                  <h3 class="text-2xl lg:text-3xl font-black text-brand-dark">
                    Mínimo 4 Sesiones
                  </h3>
                  <div class="w-10 h-10 rounded-xl bg-brand-primary/10 flex items-center justify-center shrink-0 mx-auto lg:mx-0">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
                    </svg>
                  </div>
                </div>
                <p class="text-slate-600 text-lg leading-relaxed max-w-2xl mx-auto lg:mx-0">
                  Esto permite que la piel responda profundamente y mejore visiblemente con cada visita programada.
                </p>
                <!-- Indicador de sesiones -->
                <div class="mt-4 flex gap-1 justify-center lg:justify-start">
                  <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold">1</div>
                  <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold">2</div>
                  <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold">3</div>
                  <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold">4</div>
                  <div class="w-8 h-8 rounded-lg bg-gray-200 text-gray-400 flex items-center justify-center text-sm font-bold">5+</div>
                </div>
              </div>
            </div>
          </div>

          <!-- PASO 4: RESULTADOS DESTACADOS -->
   



<style>
  /* Animación sutil de respiración para los blobs de fondo */
  @keyframes pulse-slow {
    0%, 100% { opacity: 1; transform: scale(1); blur: 100px; }
    50% { opacity: 0.8; transform: scale(1.05); blur: 120px; }
  }
  .animate-pulse-slow {
    animation: pulse-slow 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>
        </div>
      </div>
    </div>
  </section>

  <!-- SECCIÓN CTA MEJORADA -->

</section>

<script>
  // Intersection Observer mejorado para animaciones al hacer scroll
  const observerOptions = {
    threshold: 0.2,
    rootMargin: "0px 0px -50px 0px"
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        // Pequeño delay para mejor efecto visual
        setTimeout(() => {
          entry.target.classList.remove('opacity-0', 'translate-y-8', 'translate-y-10', 'scale-95');
          entry.target.classList.add('opacity-100', 'translate-y-0', 'scale-100');
        }, 100);
      }
    });
  }, observerOptions);

  // Observar todos los elementos con clase 'reveal'
  document.querySelectorAll('.reveal').forEach((el) => {
    observer.observe(el);
  });

  // Cleanup opcional
  window.addEventListener('unload', () => {
    observer.disconnect();
  });
</script>
