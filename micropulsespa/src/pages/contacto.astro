---
// src/pages/contacto.astro
import Layout from '../layouts/Layout.astro';



// Imagen de Camilla
const specialistImage = "/images/nelly-micropuntura.jpg";

// Horarios de atención
const businessHours = [
  { day: "Lunes a Sábados", hours: "9:00 AM - 7:00 PM" },
  { day: "Domingos", hours: "10:00 AM - 4:00 PM"  }
];

// Preguntas frecuentes rápidas
const quickFaqs = [
  { question: "¿Cuánto dura una sesión?", answer: "60 minutos aprox." },
  { question: "¿Duele?", answer: "Sensación tolerable." },
  { question: "¿Resultados visibles?", answer: "Desde la primera sesión" }
];

// Beneficios destacados
const benefits = [
  { icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", text: "Respuesta en  10 min maximo" },
  { icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", text: "Resultados garantizados" },
  { icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z", text: "Ubicación accesible" }
];
---

<Layout title="Contacto | Micropulse Spa - Agenda tu Cita en Tibás">

  <main class="bg-white pt-24 min-h-screen overflow-hidden max-w-7xl mx-auto">
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
      <div class="absolute top-20 left-0 w-64 h-64 text-brand-primary/5">
        <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M0 100 C 50 150, 150 150, 200 100" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" opacity="0.3"/>
          <circle cx="100" cy="100" r="40" stroke="currentColor" stroke-width="1" stroke-dasharray="6 6" opacity="0.2" fill="none"/>
        </svg>
      </div>
      <div class="absolute bottom-0 right-0 w-96 h-96 opacity-20" style="background-image: radial-gradient(circle at 2px 2px, #8E4B94 2px, transparent 0); background-size: 40px 40px;"></div>
      <div class="absolute top-1/3 left-10 w-72 h-72 border border-brand-primary/10 rounded-full blur-2xl"></div>
      <div class="absolute bottom-1/4 right-10 w-96 h-96 bg-gradient-to-br from-brand-primary/5 to-transparent rounded-full blur-3xl"></div>
    </div>

    <section class="relative py-12 px-6 lg:py-24">
      <div class="max-w-7xl mx-auto relative z-10">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
          
          <div class="lg:col-span-5 space-y-10 reveal opacity-0 -translate-x-10 transition-all duration-1000">
            <div>
              <div class="inline-flex items-center gap-2 bg-brand-primary/10 px-4 py-1.5 rounded-full mb-6 border border-brand-primary/20">
                <span class="w-2 h-2 bg-brand-primary rounded-full animate-pulse"></span>
                <span class="text-[10px] font-black tracking-[0.3em] uppercase text-brand-primary">Atención Inmediata</span>
              </div>
              <h1 class="text-5xl md:text-7xl font-black text-brand-dark tracking-tighter leading-none mb-6">
                Hablemos de <br/> <span class="text-brand-primary ">tu cambio</span>.
              </h1>
              <p class="text-slate-600 text-lg font-medium leading-relaxed max-w-md">
                Estamos en Tibás, listos para guiarte en tu proceso de regeneración dérmica. Contáctanos por cualquier medio.
              </p>
            </div>

            <div class="grid grid-cols-3 gap-4 py-6 border-y border-slate-100">
              {benefits.map((benefit) => (
                <div class="text-center group">
                  <div class="w-12 h-12 mx-auto bg-brand-primary/5 rounded-2xl flex items-center justify-center mb-3 group-hover:bg-brand-primary group-hover:text-white transition-all shadow-sm">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path d={benefit.icon} />
                    </svg>
                  </div>
                  <p class="text-[9px] font-black uppercase tracking-widest text-slate-400 group-hover:text-brand-primary transition-colors leading-tight" set:html={benefit.text}></p>
                </div>
              ))}
            </div>

            <div class="space-y-6">
              <a href="tel:+50688227210" class="flex items-center gap-5 group p-4 rounded-2xl hover:bg-brand-primary/5 transition-all">
                <div class="w-12 h-12 rounded-2xl bg-brand-primary text-white flex items-center justify-center shadow-lg shadow-brand-primary/20 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Llámanos</p>
                  <p class="text-xl font-black text-brand-dark">+506 8822-7210</p>
                </div>
              </a>

              <a href="mailto:soporte@micropulsespa.com" class="flex items-center gap-5 group p-4 rounded-2xl hover:bg-brand-primary/5 transition-all">
                <div class="w-12 h-12 rounded-2xl bg-brand-primary/10 text-brand-primary flex items-center justify-center group-hover:bg-brand-primary group-hover:text-white transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206"></path></svg>
                </div>
                <div>
                  <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">Escríbenos</p>
                  <p class="text-lg font-bold text-brand-dark">soporte@micropulsespa.com</p>
                </div>
              </a>
            </div>

            <div class="bg-slate-50 p-8 rounded-[2.5rem] border border-slate-100 shadow-inner">
              <div class="flex items-center gap-3 mb-6">
                <div class="w-2 h-8 bg-brand-primary rounded-full"></div>
                <h4 class="text-sm font-black uppercase tracking-widest text-brand-dark">Horarios de Atención</h4>
              </div>
              <div class="space-y-4">
                {businessHours.map((item) => (
                  <div class="flex justify-between items-center text-sm border-b border-slate-200 pb-3 last:border-0 last:pb-0">
                    <span class="font-bold text-slate-500">{item.day}</span>
                    <span class="font-black text-brand-dark bg-white px-3 py-1 rounded-lg shadow-sm border border-slate-100">{item.hours}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <div class="lg:col-span-7 reveal opacity-0 translate-x-10 transition-all duration-1000 delay-300">
            <div class="bg-white border border-slate-100 p-8 md:p-16 rounded-[4rem] shadow-[0_32px_64px_-16px_rgba(0,0,0,0.08)] relative">
              <div class="absolute -top-10 -right-4 md:right-20 w-28 h-28 md:w-36 md:h-36 rounded-3xl border-[10px] border-white shadow-2xl overflow-hidden z-20 group rotate-3">
                  <img src={specialistImage} alt="Camilla Ceragem" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
              </div>

              <div class="relative z-10">
                <h2 class="text-3xl md:text-5xl font-black text-brand-dark tracking-tighter uppercase mb-4">Solicita tu <span class="text-brand-primary ">Valoración</span></h2>
                <p class="text-slate-400 mb-12 font-medium">Completa el formulario y te contactaremos en minutos.</p>
                
                <form class="space-y-8">
                  <div class="grid md:grid-cols-2 gap-8">
                    <div class="relative group">
                      <input type="text" id="name" name="name" required class="w-full bg-transparent border-b-2 border-slate-200 py-4 text-lg font-medium text-brand-dark outline-none focus:border-brand-primary transition-all peer placeholder:text-transparent" placeholder="Nombre" />
                      <label for="name" class="absolute left-0 top-4 text-lg text-slate-400 pointer-events-none transition-all peer-focus:-top-6 peer-focus:text-xs peer-focus:font-black peer-focus:uppercase peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-xs">Nombre Completo</label>
                    </div>

                    <div class="relative group">
                      <input type="tel" id="phone" name="phone" required class="w-full bg-transparent border-b-2 border-slate-200 py-4 text-lg font-medium text-brand-dark outline-none focus:border-brand-primary transition-all peer placeholder:text-transparent" placeholder="Tel" />
                      <label for="phone" class="absolute left-0 top-4 text-lg text-slate-400 pointer-events-none transition-all peer-focus:-top-6 peer-focus:text-xs peer-focus:font-black peer-focus:uppercase peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-xs">Número de WhatsApp</label>
                    </div>
                  </div>

                  <div class="relative group">
                    <textarea id="message" name="message" rows="3" required class="w-full bg-transparent  border-slate-200 py-4 text-lg font-medium text-brand-dark outline-none focus:border-brand-primary transition-all peer placeholder:text-transparent resize-none" placeholder="Msg"></textarea>
                    <label for="message" class="absolute left-0 top-4 text-lg text-slate-400 pointer-events-none transition-all peer-focus:-top-6 peer-focus:text-xs peer-focus:font-black peer-focus:uppercase peer-focus:text-brand-primary peer-[:not(:placeholder-shown)]:-top-4 peer-[:not(:placeholder-shown)]:text-xs">¿Qué área te gustaría tratar?</label>
                  </div>

                  <button type="submit" class="w-full bg-brand-primary text-white py-6 rounded-3xl font-black text-xl shadow-xl shadow-brand-primary/30 hover:bg-brand-dark hover:-translate-y-1 active:scale-95 transition-all group overflow-hidden relative">
                    <span class="relative z-10">ENVIAR SOLICITUD</span>
                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
                  </button>
                  <p class="text-[10px] text-center text-slate-400 uppercase tracking-widest font-bold">Respuesta garantizada en menos de 24 horas</p>
                </form>
              </div>
            </div>

            <div class="mt-8 lg:mt-36 grid md:grid-cols-3 gap-4">
              {quickFaqs.map((faq) => (
                <div class="bg-slate-50 p-5 rounded-2xl border border-slate-100 hover:border-brand-primary/20 transition-colors">
                  <p class="font-black text-xs text-brand-primary uppercase tracking-widest mb-1">{faq.question}</p>
                  <p class="text-xs text-slate-600 font-medium">{faq.answer}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
<section class="py-2 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="bg-white rounded-[3.5rem] p-4 shadow-2xl border border-slate-100 relative group overflow-hidden">
          
          <div class="aspect-video lg:h-[500px] w-full rounded-[3rem] overflow-hidden relative transition-all duration-1000">
            
            <div class="hidden lg:block absolute bottom-8 right-8 z-20 bg-white/95 backdrop-blur-md p-6 rounded-3xl shadow-2xl max-w-xs border border-brand-primary/10 pointer-events-none md:pointer-events-auto">
              <div class="flex items-center gap-2 mb-2">
                <span class="w-2 h-2 bg-brand-primary rounded-full animate-pulse"></span>
                <h3 class="text-brand-dark font-black text-xl tracking-tight ">Nuestra Sede</h3>
              </div>
              <p class="text-slate-500 text-sm font-medium leading-relaxed mb-4 ">
                "5 ESQUINAS DE TIBAS DE SUPER BATERIAS 100 OSTE Y 75 ESTE SEPTIMA CASA ENTRANDO A MANO IZQUIERDA PORTON NEGRO."
              </p>
              <a 
                href="https://www.google.com/maps/place/Micropulsespa/@9.9475277,-84.0766619,866m/data=!3m1!1e3!4m14!1m7!3m6!1s0x81f346903a946e47:0x8e3f4334401405e6!2sMicropulsespa!8m2!3d9.9475277!4d-84.0766619!16s%2Fg%2F11yj9txy_n!3m5!1s0x81f346903a946e47:0x8e3f4334401405e6!8m2!3d9.9475277!4d-84.0766619!16s%2Fg%2F11yj9txy_n?entry=ttu&g_ep=EgoyMDI2MDMxNS4wIKXMDSoASAFQAw%3D%3D" 
                target="_blank" 
                class="inline-flex items-center gap-2 text-xs font-black text-brand-primary hover:text-brand-dark transition-all pointer-events-auto"
              >
                ABRIR EN GOOGLE MAPS 
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path d="M13.5 4.5L21 12m0 0l-7 7M21 12H3"></path>
                </svg>
              </a>
            </div>

            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3771.2106383092682!2d-84.07666189999999!3d9.9475277!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x81f346903a946e47%3A0x8e3f4334401405e6!2sMicropulsespa!5e1!3m2!1ses-419!2sco!4v1773795911757!5m2!1ses-419!2sco" 
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              class="absolute inset-0 w-full h-full  z-10"
            ></iframe>

          </div>
        </div>
      </div>
    </section>

    <section class="py-24 px-6 bg-slate-50 relative overflow-hidden">
   

       
      </div>
    </section>
  </main>

</Layout>

<script>
  const observerOptions = { threshold: 0.1 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-10', '-translate-x-10', 'translate-x-10');
        entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  html { scroll-behavior: smooth; }
  .text-brand-dark { color: #1a1523; }
  .bg-brand-dark { background-color: #1a1523; }
  .reveal { will-change: transform, opacity; }
</style>