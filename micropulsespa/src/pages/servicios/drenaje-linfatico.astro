---
import HeroDrenajeSlider from '../../components/HeroDrenajeSlider.astro';
import Layout from '../../layouts/Layout.astro';

const beneficios = [
  {
    id: "desintoxicacion",
    title: "Detox Profundo",
    subtitle: "Eliminación de Toxinas",
    desc: "Estimulamos el sistema linfático mediante movimientos rítmicos para acelerar la eliminación de líquidos retenidos y desechos metabólicos, logrando que tu cuerpo se sienta renovado.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    stat: "90%",
    statLabel: "menos retención"
  },
  {
    id: "escultural",
    title: "Contorno Definido",
    subtitle: "Moldeo Corporal",
    desc: "Al reducir la inflamación de los tejidos y mejorar la circulación, ayudamos a moldear tu figura y definir el contorno natural de tu cuerpo, eliminando la sensación de pesadez.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    stat: "4-6cm",
    statLabel: "reducción visual"
  },
  {
    id: "bienestar",
    title: "Ligereza Inmediata",
    subtitle: "Efecto Anti-estrés",
    desc: "Esta técnica suave relaja el sistema nervioso, reduciendo el cortisol. Es el tratamiento ideal para piernas cansadas, procesos postoperatorios y para mejorar la salud de la piel.",
    icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z",
    stat: "100%",
    statLabel: "sensación ligera"
  }
];

const pasos = [
  { num: "01", titulo: "Activación Ganglionar", desc: "Iniciamos desbloqueando los puntos clave del sistema linfático para asegurar un flujo correcto de los líquidos." },
  { num: "02", titulo: "Masaje Rítmico", desc: "Aplicamos presiones suaves y precisas siguiendo el recorrido linfático para movilizar la linfa estancada." },
  { num: "03", titulo: "Drenaje Mecánico", desc: "Complementamos con aparatología de baja frecuencia para potenciar la eliminación de toxinas en zonas críticas." },
  { num: "04", titulo: "Sello de Bienestar", desc: "Finalizamos con una hidratación profunda que mejora la elasticidad y el aspecto de la piel recién desinflamada." }
];

const testimonios = [
  { 
    nombre: "Karla Brenes", 
    edad: "34 años", 
    texto: "Sufría mucho de piernas hinchadas por mi trabajo. Desde la primera sesión de drenaje sentí un alivio increíble y mis jeans me quedan mucho más cómodos.", 
    resultado: "Piernas ligeras y sin dolor", 
    avatar: "KB" 
  },
  { 
    nombre: "Valeria Monge", 
    edad: "29 años", 
    texto: "Me lo recomendaron después de mi cirugía y fue lo mejor. La inflamación bajó rapidísimo y la atención en Micropulse es de otro nivel.", 
    resultado: "Recuperación acelerada", 
    avatar: "VM" 
  },
  { 
    nombre: "Mariela Castro", 
    edad: "41 años", 
    texto: "Es mi momento detox de la semana. No solo me veo más delgada, sino que me quita el estrés por completo. Salgo sintiéndome nueva.", 
    resultado: "Figura más estilizada", 
    avatar: "MC" 
  }
];
---

<Layout 
  title="Drenaje Linfático Manual | Desinflama y Moldea | Micropulse Spa"
  description="Técnica especializada para eliminar toxinas, reducir retención de líquidos y moldear tu figura. Siéntete ligera y saludable en Tibás."
>

 <HeroDrenajeSlider />

  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Beneficios Reales</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark mt-3 mb-5 tracking-tight text-balance">
          Desinflama tu cuerpo <br/>
          <span class="text-brand-primary">y recupera tu energía</span>
        </h2>
        <p class="text-slate-500 text-lg">Una técnica suave con impactos profundos en tu sistema circulatorio e inmune.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {beneficios.map((b) => (
          <div class="bg-white p-8 rounded-[2rem] border border-slate-200 hover:border-brand-primary/40 hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-brand-primary/5 to-transparent rounded-full blur-2xl"></div>
            
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-light to-brand-primary/10 flex items-center justify-center text-brand-primary mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={b.icon}></path>
              </svg>
            </div>
            
            <div class="flex items-baseline gap-1 mb-2">
              <span class="text-3xl font-black text-brand-primary">{b.stat}</span>
              <span class="text-xs font-medium text-slate-400 uppercase">{b.statLabel}</span>
            </div>
            
            <span class="text-[10px] font-black text-brand-primary/70 uppercase tracking-[0.15em]">{b.subtitle}</span>
            <h3 class="text-xl font-black text-brand-dark mt-2 mb-3 tracking-tight">{b.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{b.desc}</p>
            
            <div class="mt-6 w-full h-[2px] bg-slate-100 rounded-full overflow-hidden">
              <div class="w-0 group-hover:w-full h-full bg-gradient-to-r from-brand-primary to-brand-secondary transition-all duration-1000"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 bg-white" id="proceso">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">El Método Micropulse</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark mt-3 mb-5">
          Cómo transformamos <br/><span class="text-brand-primary">tu cuerpo en 60 minutos</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {pasos.map((paso) => (
          <div class="text-center group p-6 rounded-[2.5rem] hover:bg-slate-50 transition-all">
            <div class="w-20 h-20 mx-auto rounded-full bg-gradient-to-br from-brand-light to-brand-primary/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
              <span class="text-2xl font-black text-brand-primary">{paso.num}</span>
            </div>
            <h3 class="text-lg font-black text-brand-dark mb-2 italic tracking-tighter">{paso.titulo}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{paso.desc}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-16 bg-gradient-to-r from-brand-primary/5 to-brand-secondary/5 rounded-3xl p-8 text-center border border-brand-primary/10">
        <p class="text-brand-dark font-semibold">
          Protocolos seguros e ideales para <span class="text-brand-primary font-black uppercase tracking-widest text-sm">Postoperatorios</span> y bienestar diario.
        </p>
      </div>
    </div>
  </section>

  <section class="py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-10 mb-12">
        <div class="text-left">
          <span class="inline-block text-[10px] font-black text-brand-primary uppercase tracking-[0.3em] mb-3">
            Casos de Éxito
          </span>
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-brand-dark tracking-tighter leading-none italic">
            Lo que sienten <br/>
            <span class="text-brand-primary not-italic tracking-normal">nuestras pacientes.</span>
          </h2>
        </div>
        <div class="pb-2">
          <a href="https://wa.me/50688227210" class="group inline-flex items-center gap-2 text-brand-primary font-black text-xs uppercase tracking-[0.2em] hover:text-brand-dark transition-colors" target="_blank">
            WhatsApp Citas
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonios.map((t) => (
          <div class="bg-white p-8 rounded-3xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center text-white font-black">
                {t.avatar}
              </div>
              <div>
                <p class="font-black text-brand-dark italic leading-none">{t.nombre}</p>
                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">{t.edad}</p>
              </div>
            </div>
            <p class="text-slate-600 italic mb-6 leading-relaxed">"{t.texto}"</p>
            <div class="pt-4 border-t border-slate-100 flex justify-between items-center">
              <span class="text-[9px] font-black text-brand-primary uppercase tracking-wider">Resultado:</span>
              <p class="text-xs font-black text-brand-dark italic">{t.resultado}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Compromiso Micropulse</span>
          <h2 class="text-4xl font-black text-brand-dark mt-3 mb-6 leading-tight tracking-tighter italic">
            Dile adiós a la pesadez <br/>
            <span class="text-brand-primary not-italic">con manos expertas</span>
          </h2>
          <ul class="space-y-4 mb-10">
            {[
              { t: "Técnica Especializada", d: "Masoterapeutas capacitados en drenaje manual rítmico." },
              { t: "Moldeo Corporal", d: "Enfoque en definición de contornos y reducción de volumen." },
              { t: "Atención Post-Op", d: "Protocolos específicos para cirugías estéticas y médicas." },
              { t: "Salud Integral", d: "Mejora del aspecto de la piel y eliminación de toxinas." }
            ].map((item) => (
              <li class="flex gap-4 items-start">
                <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-xs font-black shrink-0 mt-0.5">✓</span>
                <span class="text-slate-600 text-sm"><strong class="text-brand-dark">{item.t}</strong> – {item.d}</span>
              </li>
            ))}
          </ul>
          <a href="https://wa.me/50688227210?text=Hola, quiero reservar una sesión de Drenaje Linfático" 
             class= "inline-flex items-center gap-2 bg-brand-primary text-white px-10 py-4 rounded-full font-black hover:bg-brand-dark transition-all shadow-xl shadow-brand-primary/20 text-sm uppercase tracking-widest" target="_blank">
            Agendar Mi Sesión
          </a>
        </div>
        <div class="relative group">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/20 to-brand-secondary/20 blur-[80px] rounded-full group-hover:blur-[100px] transition-all"></div>
          <div class="relative bg-slate-100 rounded-[3rem] overflow-hidden shadow-2xl border-4 border-white">
            <img src="/images/drenaje-linfatico-despues.jpg" alt="Drenaje linfático y moldeo corporal" class="w-full h-auto object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="py-28 bg-slate-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Claridad Total</span>
        <h2 class="text-5xl md:text-6xl font-black text-brand-dark mt-3 tracking-tighter italic">
          Preguntas <span class="text-brand-primary not-italic uppercase tracking-normal text-3xl md:text-4xl block md:inline ml-2">Frecuentes</span>
        </h2>
      </div>
      
      <div class="space-y-4">
        {[
          { 
            q: "¿Es un masaje reductivo?", 
            a: "No es igual. Mientras el reductivo usa más presión, el drenaje es suave y rítmico para movilizar líquidos. Sin embargo, al desinflamar, se logra un efecto visual de reducción de medidas inmediato." 
          },
          { 
            q: "¿Cuántas sesiones recomiendan?", 
            a: "Para ver cambios significativos en el contorno y la celulitis, recomendamos paquetes de 5 a 10 sesiones, realizadas 2 veces por semana." 
          },
          { 
            q: "¿Es apto después de una cirugía?", 
            a: "¡Es indispensable! Ayuda a que el cuerpo absorba el edema postquirúrgico mucho más rápido, evita fibrosis y acelera la cicatrización. Consulta siempre con tu médico." 
          },
          { 
            q: "¿Se siente dolor durante el masaje?", 
            a: "Para nada. Es una técnica extremadamente relajante. La presión es mínima ya que los vasos linfáticos están justo debajo de la piel." 
          }
        ].map((faq) => (
          <details class="group bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
            <summary class="flex justify-between items-center cursor-pointer list-none p-8 font-black text-brand-dark text-lg italic hover:text-brand-primary transition-colors">
              {faq.q}
              <span class="transition-transform group-open:rotate-180 text-brand-primary">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </summary>
            <p class="px-8 pb-8 text-slate-500 font-medium leading-relaxed border-t border-slate-50 pt-6 italic">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 lg:px-8 mb-20">
    <div class="max-w-7xl mx-auto relative overflow-hidden rounded-[3.5rem] lg:rounded-[4.5rem] shadow-2xl shadow-black/20 group">
      <div class="absolute inset-0 bg-gradient-to-r from-brand-primary to-brand-primary/90 transition-transform duration-1000 group-hover:scale-105"></div>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[120px]"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px]"></div>

      <div class="py-10 px-6 max-w-4xl mx-auto text-center relative z-10">
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-black text-white mb-6 tracking-tighter leading-tight italic">
          Libera tu cuerpo <br/> 
          <span class="text-brand-light not-italic">siéntete ligera.</span>
        </h2>
        
        <p class="text-white/80 text-lg md:text-xl mb-12 max-w-xl mx-auto font-medium leading-relaxed">
          Agenda hoy tu sesión de drenaje y empieza a desinflamar tu cuerpo de forma natural. 
          <br/><span class="text-brand-light uppercase text-xs font-black tracking-[0.3em]">Atención en Tibás, San José</span>
        </p>

        <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
          <a href="https://wa.me/50688227210?text=Hola%2C%20quiero%20agendar%20mi%20sesi%C3%B3n%20de%20Drenaje%20Linf%C3%A1tico" 
             class="bg-white text-brand-dark px-12 py-4 rounded-full font-black hover:bg-brand-light transition-all shadow-xl w-full sm:w-auto uppercase tracking-widest text-sm"
          >
            AGENDAR POR WHATSAPP
          </a>
          <a href="tel:+50688227210" class="flex items-center gap-3 text-white font-black text-xs uppercase tracking-[0.3em] hover:text-white/80 transition-opacity">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            Llamar ahora
          </a>
        </div>

        <p class="mt-12 text-white/40 text-[10px] font-black uppercase tracking-[0.5em] italic">
          Micropulse Spa · Especialistas en Bienestar Corporal
        </p>
      </div>
    </div>
  </section>

</Layout>