        ].map((faq) => (
          <details class="group bg-white rounded-2xl shadow-sm border border-slate-200">
            <summary class="flex justify-between items-center cursor-pointer list-none p-6 font-black text-zinc-800 text-lg">
              {faq.q}
              <span class="transition-transform group-open:rotate-180">
                <svg class="w-7 h-7 text-brand-primary  bg-brand-primary/20 rounded-[2rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </summary>
            <p class="px-6 pb-6 text-slate-600 border-t border-slate-100 pt-4">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 lg:px-8">
  <div class="max-w-7xl mx-auto relative overflow-hidden rounded-[3.5rem] lg:rounded-[4.5rem] shadow-2xl shadow-black/20">
    
    <div class="absolute inset-0 bg-gradient-to-r from-brand-primary to-brand-primary/90"></div>
    
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px]"></div>

    <div class="py-16  px-6 max-w-4xl mx-auto text-center relative z-10">
      <h2 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tighter">
        ¿List@ para <span class="text-brand-light italic">transformar</span> tu vida?
      </h2>
      
      <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto font-medium">
        Reserva tu primera sesión hoy. Cupos limitados por demanda.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <button 
          id="btn-reserva-ceragem-3" 
          class="bg-white text-zinc-800 px-8 py-3 rounded-full font-black hover:bg-brand-light hover:text-brand-dark transition-all shadow-2xl cursor-pointer uppercase text-xs tracking-widest"
        >
          RESERVAR AHORA
        </button>
        
        <a 
          href="tel:+50688227210" 
          class="border-2 border-white/30 text-white px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-all text-center uppercase text-xs tracking-widest"
        >
          Llamar ahora
        </a>
      </div>

      <p class="mt-8 text-white/40 text-[10px] font-bold uppercase tracking-widest">
        Micropulse Spa · Tibás · Atención personalizada
      </p>
    </div>
  </div>
</section>

<div id="modal-reserva" class="fixed inset-0 z-[150] hidden items-center justify-center p-4">
  <div id="overlay-reserva" class="absolute inset-0 bg-brand-dark/80 backdrop-blur-md transition-opacity duration-300"></div>
  <div class="relative w-full max-w-4xl max-h-[90vh] overflow-y-auto">
      <button id="cerrar-reserva" class="absolute top-6 right-6 z-50 bg-white/20 hover:bg-white/40 text-white p-2 rounded-full transition-colors cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
      <BookingFlow />
  </div>
</div>

<script>
  const initReservaCeragem = () => {
    // Todos los botones que pueden abrir el modal de Ceragem
    const btnIds = ['btn-reserva-ceragem', 'btn-reserva-ceragem-2', 'btn-reserva-ceragem-3'];
    const modal = document.getElementById('modal-reserva');
    const overlay = document.getElementById('overlay-reserva');
    const cerrar = document.getElementById('cerrar-reserva');

    const openModal = () => {
      if (modal) {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
        
        // RE-INICIALIZAR LOGICA Y SALTAR AL PASO 2
        // Usamos (window as any) para evitar errores de TypeScript
        if ((window as any).initBookingLogic) (window as any).initBookingLogic();
        if ((window as any).forceBookingStep2) (window as any).forceBookingStep2("Camilla Ceragem");
      }
    };

    const closeModal = () => {
      if (modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
      }
    };

    btnIds.forEach(id => {
      document.getElementById(id)?.addEventListener('click', openModal);
    });

    overlay?.addEventListener('click', closeModal);
    cerrar?.addEventListener('click', closeModal);
  };

  // Inicializar en carga y en cambios de Astro
  initReservaCeragem();
  document.addEventListener('astro:after-swap', initReservaCeragem);
</script>

</Layout>