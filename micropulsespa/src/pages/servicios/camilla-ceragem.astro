      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-brand-dark tracking-tighter leading-none italic">
        Lo que dicen <br/>
        <span class="text-brand-primary not-italic tracking-normal">quienes ya lo probaron.</span>
      </h2>
    </div>

    <div class="pb-2">
      <a href="https://wa.me/50688227210" 
         class="group inline-flex items-center gap-2 text-brand-primary font-black text-xs uppercase tracking-[0.2em] hover:text-zinc-800 transition-colors" target="_blank">
        Contáctanos
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonios.map((t) => (
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center text-white font-black">
                {t.avatar}
              </div>
              <div>
                <p class="font-black text-brand-dark">{t.nombre}</p>
                <p class="text-xs text-slate-400">{t.edad}</p>
              </div>
            </div>
            <p class="text-slate-600 italic mb-4">"{t.texto}"</p>
            <div class="pt-4 border-t border-slate-100">
              <span class="text-xs font-bold text-brand-primary uppercase tracking-wider">Resultado:</span>
              <p class="text-sm font-semibold text-brand-dark">{t.resultado}</p>
