        <p class="text-brand-dark font-semibold">
          <span class="text-brand-primary text-2xl font-black">+40</span> años de investigación respaldan la tecnología Ceragem
        </p>
      </div>
    </div>
  </section>

  <section class="py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
     <div class="max-w-7xl mx-auto  px-6">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-10">
    
    <div class="text-left">
      <span class="inline-block text-[10px] font-black text-brand-primary uppercase tracking-[0.3em] mb-3">
