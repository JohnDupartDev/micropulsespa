---
import Layout from '../../layouts/Layout.astro';
import BookingFlow from '../../components/BookingFlow.astro'; // Importamos el flujo de reserva

const beneficios = [
  {
    id: "postura",
    title: "Reconstruye tu Columna",
    subtitle: "Alivio del dolor",
    desc: "Aplica presión secuencial en vértebras específicas para revertir años de mala postura y devolver la curvatura natural de tu espalda. Es utilizada para tratar dolores de espalda, cuello, hombros y problemas de ciática",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    stat: "87%",
    statLabel: "mejora postural"
  },
  {
    id: "dolor",
    title: "Apaga el Dolor",
    subtitle: "Termoterapia Profunda",
    desc: "Radiación infrarroja de onda larga que penetra tejidos musculares y articulaciones. Aumenta la circulación sanguínea en un 300%, libera endorfinas y favorece la eliminación de toxinas ayudado a reducir la inflamación.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    stat: "4.7cm",
    statLabel: "penetración térmica"
  },
  {
    id: "estres",
    title: "Reconecta tu Sistema Nervioso",
    subtitle: "Frecuencia Alfa",
    desc: "Vibraciones de baja frecuencia sincronizadas con ondas cerebrales alfa. Reduce el cortisol hasta un 40% induciendo un estado de calma profunda similar a 4 horas de sueño reparador. Puede ayudar en casos de estreñimiento y colitis nerviosa.",
    icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z",
    stat: "40%",
    statLabel: "menos estrés"
  }
];

const pasos = [
  { num: "01", titulo: "Masaje y Quiropraxia", desc: "Los rodillos realizan un escaneo de la columna para adaptar el masaje a la curvatura de cada usuario." },
  { num: "02", titulo: "Acupresión y Moxibustión", desc: "Aplican presión y calor intenso en puntos específicos (puntos de acupuntura) para estimular la energía del cuerpo." },
  { num: "03", titulo: "Calor Infrarrojo", desc: "Las piedras de jade emiten calor que penetra profundamente en los tejidos, mejorando la circulación sanguínea y relajando los músculos" },
  { num: "04", titulo: "Relajación Profunda", desc: "Finalizas con una sensación de ligereza y movilidad renovada." }
];

const testimonios = [
  { 
    nombre: "María Fernanda R.", 
    edad: "52 años", 
    texto: "Llegué con una hernia lumbar diagnosticada hace 8 años. Después de 6 sesiones, puedo dormir completa sin despertarme por el dolor. La tecnología de esta camilla es impresionante.", 
    resultado: "Disminución del 90% del dolor", 
    avatar: "MF" 
  },
  { 
    nombre: "Carlos Hidalgo", 
    edad: "38 años", 
    texto: "Trabajo 10 horas sentado frente a una computadora. Mi espalda estaba completamente rígida. Con solo 3 sesiones recuperé movilidad y la tensión acumulada desapareció.", 
    resultado: "Movilidad restaurada", 
    avatar: "CH" 
  },
  { 
    nombre: "Adriana Soto", 
    edad: "45 años", 
    texto: "Sufría de insomnio crónico por estrés. La sesión de Ceragem me ayuda a resetear mi sistema nervioso. Ahora vengo dos veces por semana y mi calidad de vida cambió radicalmente.", 
    resultado: "Sueño reparador", 
    avatar: "AS" 
  }
];
---

<Layout 
  title="Camilla Ceragem  | Tecnología Médica para tu Columna | Micropulse Spa"
  description="Descubre el masaje inteligente que escanea, diagnostica y trata tu espalda. Terapia con calor infrarrojo, quiropraxia automatizada y relajación profunda en Tibás."
>

  <section class="relative pt-40 overflow-hidden bg-gradient-to-br from-white via-white to-brand-light/20">
   
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
      <div class="relative z-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-brand-primary/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6 border border-brand-primary/20">
          <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
          <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.2em]">Revitalización Sistémica Avanzada</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-brand-dark tracking-tighter mb-6 ">
          Energía y alivio <br/> 
          <span class="text-zinc-900"> para tu</span>
          <span class="text-brand-primary uppercase">cuerpo.</span>
        </h1>
        
        <p class="text-lg text-zinc-600 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
         La <strong class="text-brand-dark italic"> Camilla Ceragem </strong> fusiona sabiduría milenaria y tecnología médica para desbloquear la vitalidad de tu cuerpo. Mediante <strong class="text-brand-primary">termo-acupresión con jade</strong>, logramos una descompresión profunda que optimiza la circulación y mejora el sistema nervioso.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4 mb-10">
          <button 
             id="btn-reserva-ceragem"
             class="bg-gradient-to-r from-brand-primary to-pink-300 text-white px-5 py-3 rounded-full font-black shadow-2xl shadow-brand-primary/40 hover:-translate-y-1 transition-all text-center cursor-pointer uppercase text-xs tracking-widest"
          >
            RESERVAR EXPERIENCIA
          </button>

          <a href="#proceso" 
             class="border-2 border-brand-primary/30 text-brand-dark px-5 py-3 rounded-full font-bold hover:bg-brand-primary/5 transition-all text-center text-xs tracking-widest">
            Descubre la ciencia
          </a>
        </div>
        
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 pb-5">
          <div class="text-left pb-10">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Bienestar Garantizado</p>
            <p class="text-sm font-black text-brand-dark italic">98% de satisfacción real</p>
          </div>
        </div>
      </div>

      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/10 to-brand-secondary/30 blur-[80px] rounded-full group-hover:blur-[100px] transition-all"></div>
        <div class=" rounded-4xl bg-white overflow-hidden border-2 border-white shadow-2xl">
          <img src="/images/S-camilla.jpg" alt="Bienestar integral en Micropulse Spa" class="w-full h-full object-contain " />
          <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-md rounded-2xl p-5 flex items-center justify-between border border-brand-light">
            <div>
              <p class="text-[10px] font-black text-brand-primary uppercase tracking-widest">Efecto Sistémico</p>
