          <ul class="space-y-4 mb-8">
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Certificación FDA</strong> – Respaldo médico internacional</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Terapeutas especializados</strong> – Acompañamiento profesional durante toda la sesión</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Ambiente de lujo</strong> – Aromaterapia, música terapéutica y privacidad total</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Paquetes especiales</strong> – Desde ₡28,000 por 4 sesiones con seguimiento personalizado</span>
            </li>
          </ul>
           <button 
             id="btn-reserva-ceragem-2"
             class="inline-flex items-center gap-2 bg-brand-primary text-white px-8 py-3 rounded-full font-black hover:bg-brand-primary/90 transition-all cursor-pointer uppercase text-xs tracking-widest"
          >
            Agendar Cita
          </button>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/20 to-brand-secondary/20 blur-[80px] rounded-full"></div>
          <div class="relative bg-slate-100 rounded-3xl overflow-hidden shadow-2xl">
            <img src="/images/S-camilla.jpg" alt="Ambiente Micropulse Spa" class="w-full h-auto object-cover" />
          </div>
