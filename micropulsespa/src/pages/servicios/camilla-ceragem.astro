    </div>
  </section>

  <section class="py-28 bg-white" id="proceso">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Experiencia premium</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark mt-3 mb-5">
          Así transformamos <br/><span class="text-brand-primary">tu espalda en 40 minutos</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {pasos.map((paso) => (
