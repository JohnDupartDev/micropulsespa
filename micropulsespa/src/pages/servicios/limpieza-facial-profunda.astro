---
import HeroMenFacial from '../../components/HeroMenFacial.astro';
import Slider from '../../components/Slider.astro';
import Layout from '../../layouts/Layout.astro';


const beneficios = [
  {
    id: "purificacion",
    title: "Purificación Total",
    subtitle: "Adiós a impurezas",
    desc: "Elimina puntos negros, comedones y el exceso de grasa acumulada. Nuestras técnicas de extracción profunda limpian los poros desde la raíz, permitiendo que tu piel respire y se regenere naturalmente.",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
    stat: "95%",
    statLabel: "poros limpios"
  },
  {
    id: "renovacion",
    title: "Textura de Seda",
    subtitle: "Regeneración Celular",
    desc: "Mediante la exfoliación mecánica y química controlada, eliminamos las células muertas. Esto mejora drásticamente la textura de la piel, aportando una luminosidad y frescura inmediata al rostro.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
    stat: "100%",
    statLabel: "renovación cutánea"
  },
  {
    id: "prevencion",
    title: "Control y Balance",
    subtitle: "Piel más sana",
    desc: "Controla el exceso de grasa y previene la aparición de acné recurrente. Una piel limpia favorece la absorción de productos faciales, multiplicando la efectividad de tu rutina de cuidado personal en casa.",
    icon: "M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z",
    stat: "80%",
    statLabel: "menos sebo"
  }
];

const pasos = [
  { num: "01", titulo: "Análisis Térmico", desc: "Evaluamos tu tipo de piel para personalizar los activos y la intensidad de la exfoliación necesaria." },
  { num: "02", titulo: "Apertura y Extracción", desc: "Utilizamos vapor de ozono para abrir poros y realizar una extracción manual y con aparatología de alta precisión." },
  { num: "03", titulo: "Alta Frecuencia", desc: "Aplicamos tecnología bactericida que cierra los poros, desinflama y previene brotes tras la limpieza profunda." },
  { num: "04", titulo: "Hidratación y Sello", desc: "Finalizamos con mascarilla hidratante y protector solar para que tu rostro luzca radiante y protegido." }
];

const testimonios = [
  { 
    nombre: "Laura Méndez", 
    edad: "28 años", 
    texto: "Tenía muchos puntos negros en la nariz que nada me quitaba. Con la limpieza profunda mi piel quedó súper lisa y los poros casi ni se ven. ¡Me encantó!", 
    resultado: "Piel libre de impurezas", 
    avatar: "LM" 
  },
  { 
    nombre: "Esteban Quiros", 
    edad: "35 años", 
    texto: "Como hombre a veces descuido mi cara, pero esta sesión me quitó años de encima. La textura de la piel cambió por completo, se siente fresca.", 
    resultado: "Luminosidad inmediata", 
    avatar: "EQ" 
  },
  { 
    nombre: "Sofía Vargas", 
    edad: "42 años", 
    texto: "El ambiente de Micropulse es increíble. La limpieza no dolió y mi maquillaje ahora se ve mucho mejor porque la piel está realmente limpia.", 
    resultado: "Textura uniforme", 
    avatar: "SV" 
  }
];
---

<Layout 
  title="Limpieza Facial Profunda | Piel Radiante y Sana | Micropulse Spa"
  description="Elimina impurezas, puntos negros y exceso de grasa. Tratamiento facial avanzado con aparatología para una piel luminosa y saludable en Tibás."
>

  <section class="relative pt-40 overflow-hidden bg-gradient-to-br from-white via-white to-brand-light/20">
   
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center relative z-10">
      <div class="relative z-10 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-brand-primary/10 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6 border border-brand-primary/20">
          <span class="w-2 h-2 rounded-full bg-brand-primary animate-pulse"></span>
          <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.2em]">Cuidado Facial Avanzado</span>
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-brand-dark tracking-tighter mb-6 ">
          Piel limpia <br/> 
          <span class="text-zinc-900"> y rostro</span>
          <span class="text-brand-primary uppercase">radiante.</span>
        </h1>
        
        <p class="text-lg text-slate-600 leading-relaxed mb-8 max-w-xl mx-auto lg:mx-0">
         Nuestra <strong class="text-brand-dark italic"> Limpieza Facial Profunda </strong> elimina impurezas, células muertas y exceso de grasa. Mediante técnicas manuales y aparatología de vanguardia, logramos que tu piel respire, luzca saludable y recupere su frescura natural ✨.
        
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4 mb-10">
          <a href="https://wa.me/50688227210?text=Hola%2C%20quiero%20agendar%20una%20Limpieza%20Facial%20Profunda" 
             class="bg-gradient-to-r from-brand-primary to-pink-300 text-white px-5 py-3 rounded-full font-black shadow-2xl shadow-brand-primary/40 hover:-translate-y-1 transition-all text-center" target="_blank">
            RESERVAR EXPERIENCIA
          </a>
          <a href="#proceso" 
             class="border-2 border-brand-primary/30 text-brand-dark px-5 py-3 rounded-full font-bold hover:bg-brand-primary/5 transition-all text-center">
            Descubre el proceso
          </a>
        </div>
        
        <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 pb-5">
          <div class="text-left pb-10">
            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Cuidado Profesional</p>
            <p class="text-sm font-black text-brand-dark italic">Piel 100% renovada</p>
          </div>
        </div>
      </div>

      <div class="relative group">
        <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/10 to-brand-secondary/30 blur-[80px] rounded-full group-hover:blur-[100px] transition-all"></div>
        <div class=" rounded-4xl bg-white overflow-hidden border-2 border-white shadow-2xl">
          <img src="/images/facial-micropulse.jpg" alt="Limpieza Facial Profunda en Micropulse Spa" class="w-full h-full object-contain" />
          <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-md rounded-2xl p-5 flex items-center justify-between border border-brand-light">
            <div>
              <p class="text-[10px] font-black text-brand-primary uppercase tracking-widest">Efecto Vital</p>
              <p class="text-sm font-black text-brand-dark">Luminosidad y Pureza inmediata</p>
            </div>
            <div class="w-10 h-10 rounded-full bg-brand-primary flex items-center justify-center shadow-lg shadow-brand-primary/30">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
</section>

  <section class="py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Salud Cutánea</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark mt-3 mb-5 tracking-tight">
          Piel libre de toxinas <br/>
          <span class="text-brand-primary">rostro impecable</span>
        </h2>
        <p class="text-slate-500 text-lg">Combinamos exfoliación, extracción y nutrición para mantener una piel sana y radiante.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {beneficios.map((b) => (
          <div class="bg-white p-8 rounded-[2rem] border border-slate-200 hover:border-brand-primary/40 hover:shadow-2xl transition-all duration-500 group relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-brand-primary/5 to-transparent rounded-full blur-2xl"></div>
            
            <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-brand-light to-brand-primary/10 flex items-center justify-center text-brand-primary mb-6 group-hover:scale-110 transition-transform">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d={b.icon}></path>
              </svg>
            </div>
            
            <div class="flex items-baseline gap-1 mb-2">
              <span class="text-3xl font-black text-brand-primary">{b.stat}</span>
              <span class="text-xs font-medium text-slate-400 uppercase">{b.statLabel}</span>
            </div>
            
            <span class="text-[10px] font-black text-brand-primary/70 uppercase tracking-[0.15em]">{b.subtitle}</span>
            <h3 class="text-xl font-black text-brand-dark mt-2 mb-3">{b.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{b.desc}</p>
            
            <div class="mt-6 w-full h-[2px] bg-slate-100 rounded-full overflow-hidden">
              <div class="w-0 group-hover:w-full h-full bg-gradient-to-r from-brand-primary to-brand-secondary transition-all duration-1000"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
 <Slider />
  <section class="py-10 lg:16 bg-white" id="proceso">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">El Ritual Facial</span>
        <h2 class="text-4xl md:text-5xl font-black text-brand-dark mt-3 mb-5">
          Así renovamos <br/><span class="text-brand-primary">tu piel paso a paso</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {pasos.map((paso) => (
          <div class="text-center group">
            <div class="w-20 h-20 mx-auto rounded-full bg-gradient-to-br from-brand-light to-brand-primary/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
              <span class="text-2xl font-black text-brand-primary">{paso.num}</span>
            </div>
            <h3 class="text-lg font-black text-brand-dark mb-2">{paso.titulo}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{paso.desc}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-16 bg-gradient-to-r from-brand-primary/5 to-brand-secondary/5 rounded-3xl p-8 text-center">
        <p class="text-brand-dark font-semibold">
          Utilizamos productos <span class="text-brand-primary font-black">profesionales</span> adaptados a tu tipo de piel.
        </p>
      </div>
    </div>
  </section>
 <HeroMenFacial />

  <section class="py-28 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-10 mb-12">
    
    <div class="text-left">
      <span class="inline-block text-[10px] font-black text-brand-primary uppercase tracking-[0.3em] mb-3">
        Resultados Reales
      </span>
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-brand-dark tracking-tighter leading-none italic">
        Lo que dicen <br/>
        <span class="text-brand-primary not-italic tracking-normal">sobre su nueva piel.</span>
      </h2>
    </div>

    <div class="pb-2">
      <a href="https://wa.me/50688227210" 
         class="group inline-flex items-center gap-2 text-brand-primary font-black text-xs uppercase tracking-[0.2em] hover:text-brand-dark transition-colors" target="_blank">
        Contáctanos
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonios.map((t) => (
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-slate-100 hover:shadow-2xl transition-all">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-primary to-brand-secondary flex items-center justify-center text-white font-black">
                {t.avatar}
              </div>
              <div>
                <p class="font-black text-brand-dark">{t.nombre}</p>
                <p class="text-xs text-slate-400">{t.edad}</p>
              </div>
            </div>
            <p class="text-slate-600 italic mb-4">"{t.texto}"</p>
            <div class="pt-4 border-t border-slate-100">
              <span class="text-xs font-bold text-brand-primary uppercase tracking-wider">Resultado:</span>
              <p class="text-sm font-semibold text-brand-dark">{t.resultado}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Excelencia en estética</span>
          <h2 class="text-4xl font-black text-brand-dark mt-3 mb-6">
            Piel sana y radiante <br/>
            <span class="text-brand-primary">en las mejores manos</span>
          </h2>
          <ul class="space-y-4 mb-8">
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Aparatología avanzada</strong> – Ultrasonido y alta frecuencia profesional</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Protocolos personalizados</strong> – Tratamos tu piel según sus necesidades únicas</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Ambiente relajante</strong> – Una limpieza profunda que no sacrifica tu paz</span>
            </li>
            <li class="flex gap-3">
              <span class="w-6 h-6 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-sm font-black">✓</span>
              <span class="text-slate-600"><strong class="text-brand-dark">Resultados duraderos</strong> – Piel impecable por más tiempo</span>
            </li>
          </ul>
    <a href="https://wa.me/50688227210?text=Hola, quiero reservar una Limpieza Facial Profunda" 
                 class= "inline-flex items-center gap-2 bg-brand-primary text-white px-8 py-3 rounded-full font-black hover:bg-brand-primary/90 transition-all" target="_blank">
            Agendar Mi Facial
          </a>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-r from-brand-primary/20 to-brand-secondary/20 blur-[80px] rounded-full"></div>
          <div class="relative bg-slate-100 rounded-3xl overflow-hidden shadow-2xl">
            <img src="/images/nelly-micropuntura.jpg" alt="Limpieza facial profunda Tibás" class="w-full h-auto object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="py-28 bg-slate-50">
    <div class="max-w-4xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="text-[10px] font-black text-brand-primary uppercase tracking-[0.3em]">Resuelve tus dudas</span>
        <h2 class="text-6xl font-black text-brand-dark mt-3">
          Preguntas <span class="text-brand-primary">frecuentes</span>
        </h2>
      </div>
      
      <div class="space-y-4">
        {[
          { 
            q: "¿Duele la limpieza facial?", 
            a: "La extracción de puntos negros puede generar una leve incomodidad, pero es totalmente tolerable. Nuestros terapeutas cuidan tu piel para minimizar cualquier molestia." 
          },
          { 
            q: "¿Cada cuánto debo hacérmela?", 
            a: "Lo ideal es una vez al mes, coincidiendo con el ciclo de renovación celular de la piel, para mantener los poros limpios y prevenir brotes." 
          },
          { 
            q: "¿Queda la cara roja después?", 
            a: "Es normal presentar un ligero enrojecimiento por un par de horas debido a la manipulación y extracción, pero aplicamos mascarillas descongestivas para que salgas radiante." 
          },
          { 
            q: "¿Puedo maquillarme después?", 
            a: "Recomendamos esperar al menos 12 a 24 horas para dejar que los poros se cierren completamente y la piel absorba los nutrientes aplicados." 
          }
        ].map((faq) => (
          <details class="group bg-white rounded-2xl shadow-sm border border-slate-200">
            <summary class="flex justify-between items-center cursor-pointer list-none p-6 font-black text-brand-dark text-lg">
              {faq.q}
              <span class="transition-transform group-open:rotate-180">
                <svg class="w-7 h-7 text-brand-primary  bg-brand-primary/20 rounded-[2rem]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </span>
            </summary>
            <p class="px-6 pb-6 text-slate-600 border-t border-slate-100 pt-4">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-6 lg:px-8 mb-20">
  <div class="max-w-7xl mx-auto relative overflow-hidden rounded-[3.5rem] lg:rounded-[4.5rem] shadow-2xl shadow-black/20">
    
    <div class="absolute inset-0 bg-gradient-to-r from-brand-primary to-brand-primary/90"></div>
    
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-white/5 rounded-full blur-[100px]"></div>

    <div class="py-16  px-6 max-w-4xl mx-auto text-center relative z-10">
      <h2 class="text-4xl md:text-6xl font-black text-white mb-6 tracking-tighter">
        ¿List@ para <span class="text-brand-light italic">renovar</span> tu rostro?
      </h2>
      
      <p class="text-white/80 text-lg mb-10 max-w-xl mx-auto font-medium">
        Recupera la luminosidad de tu piel hoy mismo. Cupos limitados.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="https://wa.me/50688227210?text=Hola%2C%20quiero%20reservar%20una%20Limpieza%20Facial%20Profunda" 
          class="bg-white text-brand-dark px-8 py-3 rounded-full font-black hover:bg-brand-light hover:text-brand-dark transition-all shadow-2xl"
        >
          AGENDAR POR WHATSAPP
        </a>
        
        <a 
          href="tel:+50688227210" 
          class="border-2 border-white/30 text-white px-8 py-3 rounded-full font-bold hover:bg-white/10 transition-all text-center"
        >
          Llamar ahora
        </a>
      </div>

      <p class="mt-8 text-white/40 text-[10px] font-bold uppercase tracking-widest">
        Micropulse Spa · Tibás · Atención personalizada
      </p>
    </div>
  </div>
</section>

</Layout>