---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/hero.astro';
import Services from '../components/home/Services.astro';
import TecnicaBeneficios from '../components/home/TecnicaBeneficios.astro';
import Metodologia from '../components/home/Metodologia.astro';
import ProcesoTratamiento from '../components/home/ProcesoTratamiento.astro';
import FAQ from '../components/home/FAQ.astro';
import Pricing from '../components/home/Pricing.astro';
import Testimonials from '../components/home/Testimonials.astro';
import CicatricesTabs from '../components/home/CicatricesTabs.astro';

/**
 * SEO STRATEGY - ZIPAQUIRÁ DIGITAL
 * Optimización de palabras clave para posicionamiento local en Costa Rica.
 */
const pageTitle = "Micropulse Spa | Micropuntura Brasileña en Tibás, Costa Rica";
const pageDescription = "Especialistas en regeneración dérmica avanzada. Elimina estrías hasta un 95% con micropuntura brasileña. Bienestar integral con camilla Ceragem y Microneedling en Tibás. ¡Reserva tu valoración hoy!";
const pageKeywords = "micropuntura brasileña costa rica, eliminar estrías tibás, camilla ceragem san josé, microneedling costa rica, tratamiento estrías blancas, estética avanzada tibás, regeneración de colágeno, micropulse spa";

// JSON-LD Breadcrumbs para mejorar la apariencia en los resultados de búsqueda
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "Inicio",
    "item": "https://micropulsespa.com"
  }]
};
---

<Layout 
    title={pageTitle} 
    description={pageDescription}
>
    <meta name="keywords" content={pageKeywords} slot="head" />
    
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

    <Hero />
    <Services />
    <TecnicaBeneficios />
    <Metodologia />
    <CicatricesTabs />
    <ProcesoTratamiento />
    <Testimonials />
    <FAQ />
    <Pricing />
</Layout>

<script>
    /**
     * Optimizador de carga para SEO:
     * Asegura que las secciones críticas se prioricen para el LCP (Largest Contentful Paint)
     */
    window.addEventListener('load', () => {
        console.log("Micropulse Spa - SEO & Performance by ZipaquiraDigital.com");
    });
</script>