---
import Layout from '../layouts/Layout.astro';

---

<Layout title="Sobre Nosotros | Micropulse Spa">
  
  <main class="bg-white ">
    <section class="relative min-h-[80vh] flex items-center pt-28 overflow-hidden bg-slate-50 py-20 ">
      <div class="absolute inset-0 z-0">
        <div class="absolute top-1/4 -left-20 w-[500px] h-[500px] bg-brand-primary/10 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-1/4 -right-20 w-[400px] h-[400px] bg-brand-primary/5 rounded-full blur-[100px]"></div>
      </div>

      <div class="max-w-7xl mx-auto px-6 lg:px-12 w-full relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          
          <div class="reveal opacity-0 -translate-x-10 transition-all duration-1000">
            <div class="inline-flex items-center gap-2 bg-brand-primary/10 px-4 py-1.5 rounded-full mb-6 border border-brand-primary/20">
              <span class="w-2 h-2 bg-brand-primary rounded-full animate-ping"></span>
              <span class="text-[10px] font-black tracking-[0.3em] uppercase text-brand-primary">Pasión por la Piel</span>
            </div>
            <h2 class="text-5xl md:text-8xl font-black text-brand-dark tracking-tighter leading-[0.9] mb-8">
              Ciencia que <br/>
              <span class="text-brand-primary">embellece.</span>
            </h2>
            <p class="text-slate-600 text-lg md:text-xl leading-relaxed font-medium max-w-xl mb-10">
              Nuestra historia es el reflejo del compromiso innegociable con la belleza natural y el bienestar integral de cada paciente.
            </p>
            <div class="flex flex-wrap gap-4">
               <div class="flex items-center gap-3 bg-white px-6 py-4 rounded-2xl shadow-sm border border-slate-100">
                  <span class="text-3xl font-black text-brand-primary">5+</span>
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-tight">Años de<br/>Trayectoria</span>
               </div>
               <div class="flex items-center gap-3 bg-white px-6 py-4 rounded-2xl shadow-sm border border-slate-100">
                  <span class="text-3xl font-black text-brand-primary">+500k</span>
                  <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-tight">Vidas<br/>Renovadas</span>
               </div>
            </div>
          </div>

          <div class="relative reveal opacity-0 scale-95 transition-all duration-1000 delay-300">
            <div class="relative z-10 rounded-[4rem] overflow-hidden shadow-2xl border-[12px] border-white aspect-[4/5] lg:aspect-square">
              <img src="/images/micropuntura.jpg" alt="Specialist" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-6 -left-6 md:-left-12 bg-white/80 backdrop-blur-xl p-8 rounded-[2.5rem] shadow-2xl border border-white/50 z-20 max-w-xs hidden md:block">
               <p class="text-brand-primary font-black text-3xl mb-1 ">95%</p>
               <p class="text-brand-dark font-bold text-sm leading-tight uppercase tracking-widest">Efectividad en regeneración dérmica</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-12">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
        <div class="reveal opacity-0 -translate-x-10 transition-all duration-1000">
          <span class="text-xs font-black uppercase tracking-[0.3em] text-brand-primary">Nuestra Misión</span>
          <h3 class="mt-4 text-4xl font-black leading-tight text-brand-dark md:text-5xl tracking-tighter">
            Transformar vidas a través de la regeneración dérmica avanzada.
          </h3>
          <p class="mt-6 text-lg leading-relaxed text-slate-500 font-medium">
            En Micropulse Spa, no solo realizamos tratamientos; creamos experiencias de renovación. Nos dedicamos a elevar la confianza de nuestros clientes mediante técnicas innovadoras que respetan y potencian la biología natural de la piel.
          </p>
        </div>
        <div class="reveal opacity-0 translate-x-10 transition-all duration-1000 bg-brand-primary/10 p-10 md:p-16 rounded-[3.5rem] border border-brand-primary/20 relative overflow-hidden group">
          <div class="absolute top-0 right-0 w-32 h-32 bg-brand-primary/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:scale-150 transition-transform duration-700"></div>
          <span class="text-xs font-black uppercase tracking-[0.3em] text-brand-primary">Nuestra Visión</span>
          <h3 class="mt-4 text-3xl font-black text-brand-dark tracking-tighter ">Liderar la estética regenerativa</h3>
          <p class="mt-6 text-slate-600 font-medium leading-relaxed">
            Ser el referente internacional en Micropunción Brasileña y salud dérmica, reconocidos por nuestra ética profesional, innovación constante y los resultados extraordinarios que devolvemos a cada cuerpo que cuidamos.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-brand-primary/[0.03] py-24 border-y border-brand-primary/5">
      <div class="mx-auto max-w-7xl px-6 lg:px-12">
        <div class="flex flex-col items-center gap-16 lg:flex-row">
          <div class="relative w-full max-w-md shrink-0 reveal opacity-0 -translate-x-10 transition-all duration-1000">
            <div class="absolute -bottom-8 -right-8 h-full w-full rounded-[3rem] border-2 border-brand-primary/20"></div>
            <div class="relative z-10 aspect-[4/5] w-full rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white">
               <img alt="Camilla Ceragem" class="w-full h-full object-cover" src="/images/nelly-micropuntura.jpg"/>
            </div>
          </div>
          <div class="flex-1 reveal opacity-0 translate-x-10 transition-all duration-1000">
            <span class="text-xs font-black uppercase tracking-[0.4em] text-brand-primary">Especialista </span>
            <h3 class="mt-4 text-5xl font-black text-brand-dark tracking-tighter ">Nelly Duarte</h3>
            <p class="mt-2 text-xl font-bold text-brand-primary uppercase tracking-widest text-sm">Fundadora & Experta en Micropuntura</p>
            <div class="mt-8 space-y-6 text-lg text-slate-500 font-medium leading-relaxed">
              <p>Con más de 5 años de experiencia en el sector de la medicina estética regenerativa, Nelly  ha dedicado su carrera a perfeccionar las técnicas más avanzadas de inducción de colágeno.</p>
              <p>Certificada internacionalmente, su enfoque combina la precisión clínica con un toque artístico, asegurando que cada tratamiento sea tan único como la persona que lo recibe.</p>
            </div>
            <div class="mt-10 flex gap-10 border-t border-brand-primary/10 pt-10">
              <div>
                <p class="text-4xl font-black text-brand-primary tracking-tighter">5+</p>
                <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Años Exp.</p>
              </div>
              <div class="w-px h-12 bg-brand-primary/20"></div>
              <div>
                <p class="text-4xl font-black text-brand-primary tracking-tighter">500k+</p>
                <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Sesiones</p>
              </div>
              <div class="w-px h-12 bg-brand-primary/20"></div>
              <div>
                <p class="text-4xl font-black text-brand-primary tracking-tighter">100%</p>
                <p class="text-[10px] font-black uppercase text-slate-400 tracking-widest">Pasión</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 py-24 lg:px-12 text-center">
      <div class="reveal opacity-0 translate-y-10 transition-all duration-1000">
        <h3 class="text-4xl md:text-6xl font-black text-brand-dark tracking-tighter uppercase">Nuestros <span class="text-brand-primary ">Valores</span></h3>
        <p class="mt-4 text-slate-500 font-medium">Los pilares sobre los que construimos cada resultado.</p>
      </div>
      
      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: "Excelencia", desc: "Calidad rigurosa en cada procedimiento.", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
          { title: "Innovación", desc: "Tecnología brasileña de vanguardia.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
          { title: "Cuidado", desc: "Tratamientos 100% personalizados.", icon: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" },
          { title: "Resultados", desc: "Cambios visibles y duraderos.", icon: "M5 13l4 4L19 7" }
        ].map((v) => (
          <div class="reveal opacity-0 translate-y-10 transition-all duration-700 bg-white p-10 rounded-[2.5rem] border border-slate-100 hover:shadow-2xl hover:border-brand-primary/20 transition-all group">
            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-primary/10 text-brand-primary group-hover:bg-brand-primary group-hover:text-white transition-all">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d={v.icon}/></svg>
            </div>
            <h4 class="mt-6 text-xl font-black text-brand-dark uppercase tracking-tight">{v.title}</h4>
            <p class="mt-3 text-sm text-slate-500 font-medium">{v.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-7xl px-6 pb-24 lg:px-12">
      <div class="relative overflow-hidden rounded-[3.5rem] bg-brand-primary px-8 py-20 text-center text-white shadow-2xl md:px-16 reveal opacity-0 scale-95 transition-all duration-1000">
        <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-white/10 blur-3xl"></div>
        <div class="absolute -left-20 -bottom-20 h-80 w-80 rounded-full bg-brand-dark/20 blur-3xl"></div>
        
        <h3 class="relative z-10 text-4xl font-black md:text-6xl tracking-tighter">¿Lista para tu transformación?</h3>
        <p class="relative z-10 mt-6 mx-auto max-w-2xl text-lg text-white/80 font-light">
          Agenda una consulta personalizada con Nelly Duarte y descubre el potencial real de tu piel. Tu camino hacia la regeneración comienza aquí.
        </p>
        <div class="relative z-10 mt-12 flex flex-col items-center justify-center gap-6 sm:flex-row">
          <a href="https://wa.me/50688227210" class="w-full sm:w-auto bg-white text-brand-primary px-10 py-5 rounded-full font-black text-lg shadow-xl hover:scale-105 transition-transform active:scale-95">
             AGENDAR CONSULTA
          </a>
          <a href="#servicios" class="w-full sm:w-auto border-2 border-white/30 bg-white/5 backdrop-blur-md px-10 py-5 rounded-full font-black text-lg hover:bg-white/10 transition-all">
             VER SERVICIOS
          </a>
        </div>
      </div>
    </section>
  </main>

</Layout>

<script>
  const observerOptions = { threshold: 0.15 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-10', '-translate-x-10', 'translate-x-10', 'scale-95');
        entry.target.classList.add('opacity-100', 'translate-y-0', 'translate-x-0', 'scale-100');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
  html { scroll-behavior: smooth; }
  .reveal { will-change: transform, opacity; }
</style>