---
// Notificación flotante para conversión
---

<div 
  id="sticky-notification" 
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[90] w-[90%] max-w-md translate-y-24 opacity-0 transition-all duration-500 ease-out pointer-events-none"
>
  <div class="bg-brand-dark/95 backdrop-blur-xl p-4 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.3)] border border-white/10 flex items-center justify-between gap-4">
    
    <div class="flex items-center gap-3 pl-2">
      <div class="relative">
        <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-brand-primary">
          <img src="/images/nelly-micropuntura.jpg" alt="Neyy Duarte" class="w-full h-full object-cover" />
        </div>
        <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-brand-dark rounded-full"></span>
      </div>
      <div>
        <p class="text-white text-[11px] font-medium opacity-80 leading-none mb-1">¿Tienes dudas?</p>
        <p class="text-white text-sm font-black italic tracking-tight">¡Reserva tu cita hoy!</p>
      </div>
    </div>

    <button 
      id="btn-sticky-reserva"
      class="bg-brand-primary text-white px-6 py-3 rounded-full font-black text-[10px] uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-lg cursor-pointer"
    >
      AGENDAR
    </button>

    <button id="close-sticky" class="absolute -top-2 -right-2 bg-white text-brand-dark rounded-full p-1 shadow-md hover:bg-slate-100 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>
</div>

<script>
  // @ts-nocheck
  const sticky = document.getElementById('sticky-notification');
  const btnReserva = document.getElementById('btn-sticky-reserva');
  const closeBtn = document.getElementById('close-sticky');
  
  let isClosedManually = false;

  const handleScroll = () => {
    if (isClosedManually || !sticky) return;

    // Calcular el porcentaje de scroll
    const scrollPosition = window.scrollY;
    const windowHeight = window.innerHeight;
    const fullHeight = document.documentElement.scrollHeight;
    const scrollPercentage = (scrollPosition / (fullHeight - windowHeight)) * 100;

    if (scrollPercentage >= 60) {
      // Mostrar
      sticky.classList.remove('translate-y-24', 'opacity-0', 'pointer-events-none');
      sticky.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
    } else {
      // Ocultar
      sticky.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      sticky.classList.add('translate-y-24', 'opacity-0', 'pointer-events-none');
    }
  };

  // Integración con el modal de reserva
  btnReserva?.addEventListener('click', () => {
    const modal = document.getElementById('modal-reserva');
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      
      // Llamamos a la lógica del BookingFlow
      if (window.initBookingLogic) window.initBookingLogic();
      if (window.resetBookingFlow) window.resetBookingFlow();
    }
  });

  closeBtn?.addEventListener('click', () => {
    isClosedManually = true;
    sticky.classList.replace('opacity-100', 'opacity-0');
    sticky.classList.replace('translate-y-0', 'translate-y-24');
    setTimeout(() => sticky.remove(), 500);
  });

  window.addEventListener('scroll', handleScroll);
  // Ejecutar una vez al cargar por si ya está abajo
  handleScroll();
</script>

<style>
  #sticky-notification {
    will-change: transform, opacity;
  }
</style>