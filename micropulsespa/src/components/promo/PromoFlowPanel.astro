<div>
  <div data-panel="intro" class="space-y-6">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.24em] text-[#b76bc0]">
        ¿Cómo funciona?
      </p>

      <h3 class="mt-2 text-2xl font-black text-[#1f2024]">
        Participa en 3 pasos
      </h3>
    </div>

    <div class="space-y-4">
      <div class="flex gap-4 rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] p-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#b76bc0] text-sm font-black text-white">
          1
        </div>

        <div>
          <p class="font-black text-[#1f2024]">Ingresa tus datos</p>
          <p class="mt-1 text-sm text-[#667085]">Necesitamos validar tu participación.</p>
        </div>
      </div>

      <div class="flex gap-4 rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] p-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#b76bc0] text-sm font-black text-white">
          2
        </div>

        <div>
          <p class="font-black text-[#1f2024]">Gira la ruleta</p>
          <p class="mt-1 text-sm text-[#667085]">El backend asigna el premio de forma segura.</p>
        </div>
      </div>

      <div class="flex gap-4 rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] p-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-[#b76bc0] text-sm font-black text-white">
          3
        </div>

        <div>
          <p class="font-black text-[#1f2024]">Reclama tu premio</p>
          <p class="mt-1 text-sm text-[#667085]">Recibe un código único para WhatsApp.</p>
        </div>
      </div>
    </div>

    <button
      data-start-form
      class="w-full rounded-full bg-[#b76bc0] px-6 py-4 font-black text-white shadow-[0_10px_24px_rgba(183,107,192,.28)] transition hover:bg-[#a85cb2]"
    >
      Comenzar ahora
    </button>
  </div>

  <div data-panel="form" class="hidden space-y-4">
    <div>
      <p class="text-xs font-black uppercase tracking-[0.24em] text-[#b76bc0]">
        Registro
      </p>

      <h3 class="mt-1 text-2xl font-black text-[#1f2024]">
        Ingresa tus datos
      </h3>

      <p class="mt-2 text-sm leading-relaxed text-[#667085]">
        Solo se permite una participación por correo, teléfono o Instagram.
      </p>
    </div>

    <form data-form class="space-y-3" novalidate>
      <input
        name="fullName"
        class="w-full rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] px-4 py-4 text-[#1f2024] outline-none transition placeholder:text-[#a394a6] focus:border-[#b76bc0] focus:bg-white"
        placeholder="Nombre completo"
        autocomplete="name"
      />

      <input
        name="email"
        type="email"
        class="w-full rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] px-4 py-4 text-[#1f2024] outline-none transition placeholder:text-[#a394a6] focus:border-[#b76bc0] focus:bg-white"
        placeholder="Correo electrónico"
        autocomplete="email"
      />

      <input
        name="phone"
        class="w-full rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] px-4 py-4 text-[#1f2024] outline-none transition placeholder:text-[#a394a6] focus:border-[#b76bc0] focus:bg-white"
        placeholder="WhatsApp"
        inputmode="tel"
        autocomplete="tel"
      />

      <input
        name="instagram"
        class="w-full rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] px-4 py-4 text-[#1f2024] outline-none transition placeholder:text-[#a394a6] focus:border-[#b76bc0] focus:bg-white"
        placeholder="Usuario de Instagram"
        autocomplete="off"
      />

      <label class="flex gap-3 rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] p-4 text-xs leading-relaxed text-[#667085]">
        <input required type="checkbox" class="mt-1 accent-[#b76bc0]" />
        Acepto ser contactado por WhatsApp para validar y reclamar el premio.
      </label>

      <button
        data-submit
        class="w-full rounded-full bg-[#b76bc0] px-6 py-4 font-black text-white shadow-[0_10px_24px_rgba(183,107,192,.28)] transition hover:bg-[#a85cb2] disabled:cursor-not-allowed disabled:opacity-60"
      >
        Validar participación
      </button>
    </form>
  </div>

  <div data-panel="ready" class="hidden space-y-4 text-center">
    <div class="rounded-2xl border border-[#ead8ec] bg-[#fbf8fb] p-5">
      <p data-greeting class="font-black text-[#b76bc0]"></p>
      <p class="mt-1 text-sm text-[#667085]">
        Tu participación fue registrada. Ahora puedes girar.
      </p>
    </div>

    <button
      data-scroll-wheel
      class="w-full rounded-full bg-[#1f2024] px-6 py-4 font-black text-white shadow-[0_10px_24px_rgba(31,32,36,.16)] transition hover:bg-[#b76bc0]"
    >
      Ir a la ruleta
    </button>
  </div>

  <div data-panel="result" class="hidden space-y-4 text-center">
    <div class="rounded-[1.8rem] border border-[#ead8ec] bg-[#fbf2fc] p-6">
      <p class="text-sm font-black uppercase tracking-[0.25em] text-[#b76bc0]">
        Ganaste
      </p>

      <h3 data-result-prize class="mt-3 text-3xl font-black text-[#1f2024]"></h3>
    </div>

    <div class="rounded-2xl border border-[#ead8ec] bg-white p-4 text-left">
      <p class="text-xs uppercase tracking-[0.2em] text-[#b76bc0]">Código</p>
      <p data-result-code class="mt-1 font-mono text-xl font-black text-[#1f2024]"></p>
    </div>

    <a
      data-claim
      href="#"
      target="_blank"
      rel="noopener noreferrer"
      class="block rounded-full bg-[#25D366] px-6 py-4 font-black text-white transition hover:scale-[1.02]"
    >
      Reclamar por WhatsApp
    </a>
  </div>
</div>
