---
// src/components/Hero.astro
const beforeImage = "/images/con-estrias.jpg";
const afterImage = "/images/sin-estrias.jpg";
---

<section class="relative pt-28 pb-20 px-6 lg:pt-44 overflow-hidden">
  <div class="absolute top-0 right-0 -z-10 w-full lg:w-2/3 h-full bg-gradient-to-br from-brand-light/40 via-white to-transparent opacity-70"></div>
  <div class="absolute top-24 -right-24 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
    
    <div class="space-y-10">
      <div class="space-y-6">
        <h1 class="text-xl md:text-4xl font-bold text-brand-dark leading-[1.05] tracking-tight">
          Rejuvenece tu Piel con <br />
          <span class="text-brand-primary text-4xl md:text-5xl block mt-2">Micro puntura brasileña</span>
        </h1>
        
        <div class="space-y-2">
          <h2 class="text-xl md:text-2xl font-black text-brand-dark tracking-[0.2em] uppercase">
            Eliminamos hasta el 95%
          </h2>
          <p class="text-brand-primary font-semibold text-lg uppercase tracking-wider">Las estrías y cicatrices.</p>
        </div>

        <p class="text-gray-600 text-lg md:text-xl leading-relaxed max-w-lg">
          Descubre cómo puedes decir adiós a las marcas en tu piel con el revolucionario método de <strong>micropuntura brasileña</strong>. Regeneramos tu confianza desde el interior.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-5">
        <a 
          href="https://wa.me/50688227210" 
          target="_blank"
          class="bg-brand-primary text-white px-10 py-5 rounded-full font-bold text-center hover:bg-brand-dark transition-all duration-300 shadow-xl shadow-brand-primary/25 hover:-translate-y-1"
        >
          ¡Reserva tu cita ahora!
        </a>
      </div>

      <div class="flex items-center gap-5 pt-6 border-t border-brand-light w-fit">
        <div class="flex -space-x-4">
          <div class="w-12 h-12 rounded-full border-4 border-white bg-brand-light flex items-center justify-center text-[10px] font-bold">M</div>
          <div class="w-12 h-12 rounded-full border-4 border-white bg-brand-primary/20 flex items-center justify-center text-[10px] font-bold">P</div>
          <div class="w-12 h-12 rounded-full border-4 border-white bg-brand-dark text-white flex items-center justify-center text-[10px] font-bold">S</div>
        </div>
        <div class="text-sm">
          <div class="flex text-brand-primary mb-0.5">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>
          <p class="font-bold text-brand-dark">5.0/5 <span class="font-normal text-gray-500 ml-1">"Resultados reales"</span></p>
        </div>
      </div>
    </div>

    <div class="relative group">
      <div class="relative z-10 rounded-[2rem] overflow-hidden shadow-2xl transition-transform duration-500 select-none aspect-square md:aspect-auto">
        <div id="image-comparison-slider" class="relative w-full h-full min-h-[400px] overflow-hidden cursor-ew-resize bg-gray-200">
            <img 
                src={afterImage} 
                alt="Después" 
                class="absolute inset-0 w-full h-full object-cover"
                onload="this.parentElement.classList.remove('bg-gray-200')"
            />
            
            <div id="before-image-container" class="absolute inset-0 w-1/2 overflow-hidden border-r-4 border-white shadow-2xl z-10">
                <img 
                    id="before-img-el"
                    src={beforeImage} 
                    alt="Antes" 
                    class="absolute inset-0 h-full max-w-none object-cover"
                />
                <div class="absolute top-4 left-4 bg-brand-dark/60 backdrop-blur-md text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Antes</div>
            </div>

            <div class="absolute top-4 right-4 bg-brand-primary/80 backdrop-blur-md text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">Después</div>

            <div id="slider-handle" class="absolute top-0 bottom-0 left-1/2 w-1 bg-white -ml-0.5 flex items-center justify-center z-20">
                <div class="w-10 h-10 bg-white rounded-full shadow-2xl flex items-center justify-center border-4 border-brand-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-brand-primary"><path d="m9 18-6-6 6-6"/><path d="m15 6 6 6-6 6"/></svg>
                </div>
            </div>
        </div>
      </div>
      
      <div class="hidden lg:block absolute -bottom-8 -left-8 bg-white p-8 rounded-3xl shadow-2xl z-20 border-l-8 border-brand-primary animate-bounce-slow">
        <p class="text-5xl font-black text-brand-primary mb-1">48%</p>
        <p class="text-sm font-bold text-brand-dark leading-tight">Mejora de la<br/>Elasticidad</p>
        <div class="w-full bg-brand-light h-1.5 rounded-full mt-4">
          <div class="bg-brand-primary h-full w-[48%] rounded-full"></div>
        </div>
      </div>

      <div class="absolute -top-10 -right-10 w-full h-full border-2 border-brand-primary/20 rounded-[2rem] -z-10 translate-x-4 translate-y-4"></div>
    </div>

  </div>
</section>

<script>
    const initSlider = () => {
        const slider = document.getElementById('image-comparison-slider');
        const beforeContainer = document.getElementById('before-image-container');
        const handle = document.getElementById('slider-handle');
        const beforeImg = document.getElementById('before-img-el') as HTMLImageElement;

        if (!slider || !beforeContainer || !handle || !beforeImg) return;

        let isResizing = false;

        const updateDimensions = () => {
            const width = slider.offsetWidth;
            beforeImg.style.width = `${width}px`;
        };

        const setPosition = (x: number) => {
            const rect = slider.getBoundingClientRect();
            let position = ((x - rect.left) / rect.width) * 100;
            if (position < 0) position = 0;
            if (position > 100) position = 100;
            
            beforeContainer.style.width = `${position}%`;
            handle.style.left = `${position}%`;
        };

        // Eventos
        const onMove = (e: any) => {
            if (!isResizing) return;
            const x = e.pageX || e.touches?.[0].pageX;
            setPosition(x);
        };

        slider.addEventListener('mousedown', () => isResizing = true);
        slider.addEventListener('touchstart', () => isResizing = true);
        window.addEventListener('mouseup', () => isResizing = false);
        window.addEventListener('touchend', () => isResizing = false);
        window.addEventListener('mousemove', onMove);
        window.addEventListener('touchmove', onMove);

        // Inicializar y observar cambios de tamaño
        updateDimensions();
        window.addEventListener('resize', updateDimensions);
        
        // Re-inicializar cuando la imagen cargue por si acaso
        beforeImg.onload = updateDimensions;
    };

    // Ejecutar en carga y tras navegación de Astro (si usas View Transitions)
    initSlider();
    document.addEventListener('astro:after-swap', initSlider);
</script>

<style>
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-bounce-slow {
    animation: bounce-slow 4s ease-in-out infinite;
  }
  
  img {
    user-select: none;
    pointer-events: none;
  }
  
  #image-comparison-slider {
    touch-action: pan-y;
  }
</style>