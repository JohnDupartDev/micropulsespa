---

<section class="relative py-20 md:py-28 px-4 sm:px-6 overflow-hidden bg-gradient-to-b from-[#E5D1E7] to-white">
  <!-- Elementos decorativos de fondo -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-20 left-10 w-64 h-64 bg-[#8E4B94]/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-[#8E4B94]/5 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[#8E4B94]/5 via-transparent to-transparent"></div>
  </div>

  <div class="max-w-6xl mx-auto relative z-10">
    
    <!-- HEADER CON DISEÑO MODERNO -->
    <div class="flex flex-col lg:flex-row gap-12 items-center mb-20">
      <!-- Tarjeta de título con efecto glass -->
      <div class="lg:w-1/3 reveal opacity-0 -translate-x-10 transition-all duration-1000">
        <div class="relative group">
          <!-- Efecto de glow -->
          <div class="absolute -inset-1 bg-gradient-to-r from-[#8E4B94]/20 to-[#8E4B94]/40 rounded-[5rem] blur-xl opacity-70 group-hover:opacity-100 transition-opacity"></div>
          
          <!-- Tarjeta principal -->
          <div class="relative bg-white/90 backdrop-blur-xl p-10 rounded-tr-[5rem] rounded-bl-[5rem] rounded-tl-3xl rounded-br-3xl shadow-2xl border border-white/60">
            <!-- Línea decorativa superior -->
            <div class="absolute top-0 left-10 right-10 h-1 bg-gradient-to-r from-transparent via-[#8E4B94]/30 to-transparent rounded-full"></div>
            
            <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-[#8E4B94] leading-[1.1] mb-6 tracking-tighter">
              Proceso<br/>de<span class="relative inline-block ml-2">
                <span class="relative z-10">Tratamiento</span>
                <span class="absolute -bottom-2 left-0 w-full h-3 bg-[#8E4B94]/20 -rotate-1 rounded-full"></span>
              </span>
            </h2>
            
            <p class="text-[#8E4B94]/80 font-medium text-lg leading-relaxed">
              Conoce el proceso que experimenta tu piel antes, durante y después del procedimiento de Micropuntura.
            </p>
            
            <!-- Indicador de pasos -->
            <div class="flex gap-2 mt-6">
              <div class="w-12 h-1 bg-[#8E4B94]/30 rounded-full overflow-hidden">
                <div class="w-1/3 h-full bg-[#8E4B94] rounded-full"></div>
              </div>
              <span class="text-xs text-[#8E4B94]/60 font-medium">5 fases</span>
            </div>
          </div>
        </div>
      </div>

      <!-- PRIMERAS 2 TARJETAS (Antes y Durante) -->
      <div class="lg:w-2/3 grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
        {steps.slice(0, 2).map((step, index) => (
          <div 
            class={`reveal opacity-0 translate-y-10 transition-all duration-700 delay-[${index * 200}ms] group`}
            style={{ transitionDelay: `${index * 200}ms` }}
          >
            <div class="relative h-full">
              <!-- Efecto de hover glow -->
              <div class="absolute -inset-1 bg-gradient-to-r from-[#8E4B94]/20 to-transparent rounded-[3rem] blur-md opacity-0 group-hover:opacity-100 transition-opacity"></div>
              
              <!-- Tarjeta principal -->
              <div class="relative bg-white/80 backdrop-blur-sm rounded-[2.5rem] p-6 shadow-xl border border-white/60 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2">
                
                <!-- Badge de tiempo -->
                <div class=" absolute top-4 right-2 lg:right-4 bg-[#8E4B94]/10 backdrop-blur-sm px-3 py-1 rounded-full border border-[#8E4B94]/20">
                  <span class="text-[10px] font-bold text-[#8E4B94] uppercase tracking-wider">{step.time}</span>
                </div>
                
                <!-- Título con icono -->
                <div class="flex items-center gap-3 mb-4">
