    }
  }
  
  /* Mejorar legibilidad */
  .text-\[8E4B94\]\/70 {
    line-height: 1.6;
  }
  
  /* Efecto de glassmorfismo consistente */
  .backdrop-blur-sm {
    backdrop-filter: blur(8px);
