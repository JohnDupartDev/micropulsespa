    </div>

    <!-- SIGUIENTES 3 TARJETAS (Días 1-14, 14-26, 28) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mt-12">
      {steps.slice(2).map((step, index) => (
        <div 
