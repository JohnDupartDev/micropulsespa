            <!-- Tarjeta principal -->
            <div class="relative bg-white/80 backdrop-blur-sm rounded-[2.5rem] p-6 shadow-xl border border-white/60 hover:shadow-2xl transition-all duration-500 hover:-translate-y-2 h-full flex flex-col">
              
              <!-- Badge de tiempo -->
