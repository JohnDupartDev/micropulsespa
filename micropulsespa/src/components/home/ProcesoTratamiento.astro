                    </svg>
                  </div>
                  <span class="text-lg font-black text-[#8E4B94] uppercase tracking-wider">{step.title}</span>
                </div>
                
                <!-- Imagen con efecto de vidrio -->
                <div class="relative mb-4">
                  <div class="absolute inset-0 bg-gradient-to-t from-[#8E4B94]/20 to-transparent rounded-[2rem] opacity-0 group-hover:opacity-100 transition-opacity"></div>
