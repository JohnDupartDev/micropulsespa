                    {step.image ? (
                      <img 
                        src={step.image} 
                        alt={step.title} 
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#8E4B94]/10 to-[#8E4B94]/5">
                        <svg class="w-12 h-12 text-[#8E4B94]/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
